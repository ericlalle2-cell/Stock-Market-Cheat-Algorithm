# Create the file (choose one):

# Windows (Command Prompt):
type nul > .gitignore

# Windows (PowerShell):
New-Item .gitignore

# Mac/Linux:
touch .gitignore
```

**Now edit .gitignore and add this content:**
```
# =============================================================================
# Stock Trading Advisor - Git Ignore File
# Prevents sensitive and unnecessary files from being pushed to GitHub
# =============================================================================

# CRITICAL: Never commit these files (contain secrets/credentials)
.env
*.env
.env.local
.env.*.local

# Python cache and compiled files
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
env/
ENV/
env.bak/
venv.bak/

# IDEs and editors
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
logs/
*.log

# Database files (if using SQLite locally)
data/
*.db
*.sqlite
*.sqlite3

# Jupyter Notebook checkpoints
.ipynb_checkpoints

# Test coverage
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# API keys and credentials (just in case)
*_keys.txt
*_credentials.txt
secrets.json

# OS files
Thumbs.db
.DS_Store
desktop.ini

# Temporary files
*.tmp
*.temp
*.bak